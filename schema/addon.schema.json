{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Addon Pack",
  "description": "Nexus命令助手拓展包格式规范 v1.0.0",
  "type": "object",
  "required": ["id", "name", "version", "author"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "拓展包唯一标识符，使用反向域名或命名空间格式",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$",
      "minLength": 2,
      "maxLength": 64,
      "examples": ["com.example.myaddon", "my_addon_pack"]
    },
    "name": {
      "type": "string",
      "description": "拓展包显示名称",
      "minLength": 1,
      "maxLength": 32
    },
    "description": {
      "type": "string",
      "description": "拓展包描述",
      "default": "",
      "maxLength": 200
    },
    "version": {
      "type": "string",
      "description": "语义化版本号 (MAJOR.MINOR.PATCH)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.1.3"]
    },
    "author": {
      "type": "string",
      "description": "作者名称",
      "minLength": 1,
      "maxLength": 32
    },
    "icon": {
      "type": "string",
      "description": "图标名称（预留字段）",
      "default": ""
    },
    "blocks": {
      "type": "array",
      "description": "自定义方块列表",
      "items": { "$ref": "#/definitions/block" },
      "default": []
    },
    "items": {
      "type": "array",
      "description": "自定义物品列表",
      "items": { "$ref": "#/definitions/item" },
      "default": []
    },
    "sounds": {
      "type": "array",
      "description": "自定义音效列表",
      "items": { "$ref": "#/definitions/sound" },
      "default": []
    },
    "particles": {
      "type": "array",
      "description": "自定义粒子列表",
      "items": { "$ref": "#/definitions/particle" },
      "default": []
    },
    "commands": {
      "type": "array",
      "description": "自定义快捷命令列表",
      "items": { "$ref": "#/definitions/savedCommand" },
      "default": []
    },
    "templates": {
      "type": "array",
      "description": "自定义命令模板列表",
      "items": { "$ref": "#/definitions/savedCommand" },
      "default": []
    }
  },
  "definitions": {
    "block": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "方块ID（命名空间:名称）",
          "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
          "examples": ["minecraft:stone", "custom:ruby_block"]
        },
        "name": {
          "type": "string",
          "description": "方块中文名称",
          "minLength": 1,
          "maxLength": 32
        },
        "category": {
          "type": "string",
          "description": "分类名称",
          "default": "其他",
          "maxLength": 16
        },
        "description": {
          "type": "string",
          "description": "方块描述",
          "default": "",
          "maxLength": 100
        }
      }
    },
    "item": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "物品ID（命名空间:名称）",
          "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
          "examples": ["minecraft:diamond_sword", "custom:magic_wand"]
        },
        "name": {
          "type": "string",
          "description": "物品中文名称",
          "minLength": 1,
          "maxLength": 32
        },
        "category": {
          "type": "string",
          "description": "分类名称",
          "default": "其他",
          "maxLength": 16
        },
        "description": {
          "type": "string",
          "description": "物品描述",
          "default": "",
          "maxLength": 100
        }
      }
    },
    "sound": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "音效ID（命名空间:名称）",
          "pattern": "^[a-z][a-z0-9_.]*:[a-z][a-z0-9_.]*$",
          "examples": ["minecraft:block.note_block.harp", "custom:magic_chime"]
        },
        "name": {
          "type": "string",
          "description": "音效中文名称",
          "minLength": 1,
          "maxLength": 32
        },
        "category": {
          "type": "string",
          "description": "分类名称",
          "default": "其他",
          "maxLength": 16
        },
        "description": {
          "type": "string",
          "description": "音效描述",
          "default": "",
          "maxLength": 100
        },
        "volume": {
          "type": "string",
          "description": "默认音量",
          "default": "1"
        },
        "pitch": {
          "type": "string",
          "description": "默认音调",
          "default": "1"
        }
      }
    },
    "particle": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "粒子ID（命名空间:名称）",
          "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
          "examples": ["minecraft:heart", "custom:star_sparkle"]
        },
        "name": {
          "type": "string",
          "description": "粒子中文名称",
          "minLength": 1,
          "maxLength": 32
        },
        "category": {
          "type": "string",
          "description": "分类名称",
          "default": "其他",
          "maxLength": 16
        },
        "description": {
          "type": "string",
          "description": "粒子描述",
          "default": "",
          "maxLength": 100
        },
        "hasColor": {
          "type": "boolean",
          "description": "是否支持颜色参数",
          "default": true
        }
      }
    },
    "savedCommand": {
      "type": "object",
      "required": ["id", "command", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "命令唯一ID",
          "pattern": "^[a-z][a-z0-9_]*:[a-z][a-z0-9_]*$",
          "minLength": 3,
          "maxLength": 64
        },
        "command": {
          "type": "string",
          "description": "命令内容（以/开头）",
          "pattern": "^/.*$",
          "minLength": 2,
          "maxLength": 500
        },
        "name": {
          "type": "string",
          "description": "命令显示名称",
          "minLength": 1,
          "maxLength": 32
        },
        "description": {
          "type": "string",
          "description": "命令描述",
          "default": "",
          "maxLength": 100
        },
        "category": {
          "type": "string",
          "description": "分类名称",
          "default": "其他",
          "maxLength": 16
        }
      }
    }
  }
}
