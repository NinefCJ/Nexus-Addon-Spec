{
  "id": "example.basic_addon",
  "name": "基础示例拓展包",
  "description": "展示拓展包基本结构的示例，包含各种类型的自定义内容",
  "version": "1.0.0",
  "author": "Nexus Team",
  "blocks": [
    {
      "id": "custom:ruby_block",
      "name": "红宝石块",
      "category": "建筑",
      "description": "由红宝石制成的装饰方块"
    },
    {
      "id": "custom:crystal_ore",
      "name": "水晶矿石",
      "category": "自然",
      "description": "深山中的神秘水晶矿"
    },
    {
      "id": "custom:magic_glass",
      "name": "魔法玻璃",
      "category": "装饰",
      "description": "会发光的魔法玻璃"
    }
  ],
  "items": [
    {
      "id": "custom:ruby_sword",
      "name": "红宝石剑",
      "category": "武器",
      "description": "锋利的红宝石制成的剑"
    },
    {
      "id": "custom:magic_wand",
      "name": "魔法魔杖",
      "category": "工具",
      "description": "可以释放魔法的魔杖"
    },
    {
      "id": "custom:healing_potion",
      "name": "治疗药水",
      "category": "食物",
      "description": "恢复生命值的神奇药水"
    }
  ],
  "sounds": [
    {
      "id": "custom:magic.chime",
      "name": "魔法铃声",
      "category": "魔法",
      "description": "神奇的魔法音效",
      "volume": "1",
      "pitch": "1.2"
    },
    {
      "id": "custom:explosion.magic",
      "name": "魔法爆炸",
      "category": "魔法",
      "description": "魔法爆炸音效",
      "volume": "0.8",
      "pitch": "1"
    }
  ],
  "particles": [
    {
      "id": "custom:star_sparkle",
      "name": "星星闪光",
      "category": "魔法",
      "description": "闪亮的星星粒子效果",
      "hasColor": true
    },
    {
      "id": "custom:magic_dust",
      "name": "魔法粉末",
      "category": "魔法",
      "description": "漂浮的魔法粉末",
      "hasColor": true
    }
  ],
  "commands": [
    {
      "id": "custom:fly_effect",
      "command": "/effect @s levitation 10 1 true",
      "name": "飞行效果",
      "description": "给玩家10秒的漂浮效果",
      "category": "实用"
    },
    {
      "id": "custom:heal_self",
      "command": "/effect @s instant_health 1 2",
      "name": "自我治疗",
      "description": "立即恢复大量生命值",
      "category": "实用"
    },
    {
      "id": "custom:night_vision",
      "command": "/effect @s night_vision 600 1 true",
      "name": "夜视效果",
      "description": "获得10分钟夜视效果",
      "category": "实用"
    }
  ],
  "templates": [
    {
      "id": "custom:quick_house",
      "command": "/fill ~-5 ~ ~-5 ~5 ~5 ~5 stone hollow",
      "name": "快速造房",
      "description": "快速生成一个石屋框架",
      "category": "建筑"
    },
    {
      "id": "custom:sphere_template",
      "command": "/fill ~-5 ~-5 ~-5 ~5 ~5 ~5 stone",
      "name": "立方体",
      "description": "生成一个实心立方体",
      "category": "建筑"
    }
  ]
}
